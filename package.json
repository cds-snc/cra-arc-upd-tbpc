{
  "name": "dua-upd",
  "version": "4.3.3",
  "license": "MIT",
  "scripts": {
    "ng": "nx",
    "start": "set NODE_OPTIONS=\"--max-old-space-size=6144\"& nx run-many --target=serve --projects=api,upd --parallel",
    "dev": "set NX_NATIVE_COMMAND_RUNNER=false& nx run-many --target=serve --projects=api,upd --parallel",
    "preview": "nx run-many --target=preview --projects=api,upd --parallel --output-style=static",
    "build": "nx run-many --target=build --projects=api,upd,db-updater,db-cli --parallel=false --prod --output-style=static",
    "build:parallel": "nx run-many --target=build --projects=api,upd,db-updater,db-cli --parallel --prod --output-style=static",
    "compodoc": "nx run upd:compodoc --serve --port 8081",
    "db-cli": "node -r @swc-node/register apps/db-cli/src/main.ts",
    "db-updater": "npm run db-cli update",
    "db-repair": "npm run db-cli db-repair",
    "db-repopulate": "npm run db-cli repopulate",
    "db-populate": "npm run db-cli populate",
    "db-script": "node -r @swc-node/register apps/db-cli/src/main.ts run-script",
    "deploy": "git pull && cd docker && docker-compose pull && docker-compose up -d",
    "deploy:local": "git pull && cd docker && docker compose -f docker-compose.local.yml build && docker compose -f docker-compose.local.yml up -d",
    "docker-dev:build": "docker compose -f ./docker/docker-compose.dev.local.yml build",
    "docker-dev:deps": "nx run-many --target=build --projects=api,upd --prod --parallel",
    "docker-dev:up": "docker compose -f ./docker/docker-compose.dev.local.yml up -d",
    "docker-dev": "npm run docker-dev:deps && npm run docker-dev:build && npm run docker-dev:up",
    "lint": "nx run-many --target=lint --projects=api,upd,db-updater,db-cli --parallel",
    "logs": "nx run log-viewer:serve:production",
    "test": "nx test",
    "analyze-bundle": "webpack-bundle-analyzer dist/apps/upd/stats.json",
    "analyze-bundle:api": "webpack-bundle-analyzer dist/apps/api/stats.json",
    "pre-pr": "npm run lint && npm run build:parallel",
    "translations": "npm run db-script -- -ngenerateTaskTranslations",
    "aws-sso": "bash .devcontainer/aws-sso-init.sh",
    "mongo-parquet:sync": "cd python/mongo-parquet && uv sync",
    "mongo-parquet": "cd python/mongo-parquet/src && uv run mongo_parquet",
    "mongo-parquet:download": "npm run mongo-parquet -- --download-from-remote",
    "mongo-parquet:download-sample": "npm run mongo-parquet -- --download-from-remote --sample",
    "mongo-parquet:upload": "npm run mongo-parquet -- --upload-to-remote",
    "mongo-parquet:sync-parquet": "npm run mongo-parquet -- --sync-parquet --cleanup-temp",
    "mongo-parquet:recalc-views": "npm run mongo-parquet -- --recalculate-views --cleanup-temp",
    "mongo-parquet:sync-parquet-sample": "npm run mongo-parquet -- --sync-parquet --sample --cleanup-temp",
    "mongo-parquet:recalc-views-sample": "npm run mongo-parquet -- --recalculate-views --sample --cleanup-temp",
    "mongo-parquet:seed-mongo": "npm run mongo-parquet -- --import-to-mongo --from-remote --sample",
    "mongo-parquet:seed-mongo-local": "npm run mongo-parquet -- --import-to-mongo --sample",
    "mongo-parquet:seed-mongo-full": "npm run mongo-parquet -- --import-to-mongo --from-remote",
    "mongo-parquet:seed-mongo-full-local": "npm run mongo-parquet -- --import-to-mongo",
    "mongo-parquet:export": "npm run mongo-parquet -- --export-from-mongo",
    "mongo-parquet:export-sample": "npm run mongo-parquet -- --export-from-mongo --sample",
    "update-pages:sync": "cd python/update-pages && uv sync",
    "update-pages": "cd python/update-pages/src && uv run update_pages",
    "bun-script": "bun ./scripts/bun-script.ts"
  },
  "private": true,
