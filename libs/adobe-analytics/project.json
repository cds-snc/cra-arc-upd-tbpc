{
  "name": "adobe-analytics",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/adobe-analytics/src",
  "projectType": "library",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@nx/js:swc",
      "outputs": [
        "{options.outputPath}"
      ],
      "options": {
        "outputPath": "dist/libs/adobe-analytics",
        "tsConfig": "libs/adobe-analytics/tsconfig.lib.json",
        "packageJson": "libs/adobe-analytics/package.json",
        "main": "libs/adobe-analytics/src/index.ts",
        "assets": [
          "libs/adobe-analytics/*.md"
        ]
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": [
        "{workspaceRoot}/coverage/{projectRoot}"
      ],
      "options": {
        "jestConfig": "libs/adobe-analytics/jest.config.ts"
      }
    }
  }
}
