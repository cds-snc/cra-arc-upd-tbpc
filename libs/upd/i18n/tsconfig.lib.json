{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../../dist/out-tsc",
    "declaration": true,
    "declarationMap": true,
    "inlineSources": true,
    "types": [],
    "target": "ES2022",
    "useDefineForClassFields": false,
    "moduleResolution": "bundler"
  },
  "exclude": ["**/*.test.ts", "**/*.spec.ts"],
  "include": ["**/*.ts"]
}
